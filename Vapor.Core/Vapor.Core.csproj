<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>netstandard2.0</TargetFramework>
        <LangVersion>latest</LangVersion>
        <Nullable>enable</Nullable>
        
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <Authors>Spicco D'Aura</Authors>
        <Version>1.0.0-preview</Version>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <Description>A high-performance, ultra-low latency Full-Duplex IPC framework built on Shared Memory (Memory-Mapped Files) and native OS synchronization. Designed for zero-allocation cross-process communication with 0% CPU overhead at rest. Perfect for heavy server-side integrations, external consoles, and local microservices.</Description>
        <PackageIcon>Vapor.png</PackageIcon>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="System.Memory" Version="4.5.5" />
    </ItemGroup>
    <ItemGroup>
        <None Include="Media\Vapor.png" Pack="true" PackagePath="\" />
    </ItemGroup>
    
</Project>